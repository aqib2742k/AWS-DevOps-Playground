pipeline {
    agent any

    environment {
        AWS_ACCOUNT_ID     = credentials('aws-account-id')
        AWS_REGION         = 'us-east-1'
        ECR_REPO_NAME      = 'microservice-app'
        ECR_REGISTRY       = "${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com"
        IMAGE_TAG          = "${BUILD_NUMBER}"
        SONAR_PROJECT_KEY  = 'microservice-app'
    }

    stages {

        stage('Checkout') {
            steps {
                git branch: 'main', url: 'https://github.com/your-repo/microservice-app.git'
            }
        }

        stage('Build') {
            steps {
                sh 'mvn clean package -DskipTests'
            }
        }

        stage('Unit Tests') {
            steps {
                sh 'mvn test'
            }
            post {
                always {
                    junit 'target/surefire-reports/*.xml'
                }
            }
        }

        stage('SonarQube Analysis') {
            steps {
                withSonarQubeEnv('SonarQube') {
                    sh '''
                        mvn sonar:sonar \
                        -Dsonar.projectKey=${SONAR_PROJECT_KEY} \
                        -Dsonar.host.url=${SONAR_HOST_URL} \
                        -Dsonar.login=${SONAR_AUTH_TOKEN}
                    '''
                }
            }
        }

        stage('Quality Gate') {
            steps {
                timeout(time: 5, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true
                }
            }
        }

        stage('Docker Build') {
            steps {
                script {
                    dockerImage = docker.build("${ECR_REGISTRY}/${ECR_REPO_NAME}:${IMAGE_TAG}")
                }
            }
        }

        stage('Push to ECR') {
            steps {
                script {
                    withAWS(credentials: 'aws-credentials', region: "${AWS_REGION}") {
                        sh """
                            aws ecr get-login-password --region ${AWS_REGION} | \
                            docker login --username AWS --password-stdin ${ECR_REGISTRY}

                            docker push ${ECR_REGISTRY}/${ECR_REPO_NAME}:${IMAGE_TAG}

                            docker tag ${ECR_REGISTRY}/${ECR_REPO_NAME}:${IMAGE_TAG} \
                                       ${ECR_REGISTRY}/${ECR_REPO_NAME}:latest
                            docker push ${ECR_REGISTRY}/${ECR_REPO_NAME}:latest
                        """
                    }
                }
            }
        }

        stage('Update K8s Manifest') {
            steps {
                script {
                    sh """
                        sed -i 's|image:.*|image: ${ECR_REGISTRY}/${ECR_REPO_NAME}:${IMAGE_TAG}|g' \
                        kubernetes/deployment.yaml
                    """
                    sh """
                        git config user.email "jenkins@ci.com"
                        git config user.name "Jenkins"
                        git add kubernetes/deployment.yaml
                        git commit -m "Update image tag to ${IMAGE_TAG} [skip ci]"
                        git push origin main
                    """
                }
            }
        }
    }

    post {
        success {
            echo "Pipeline succeeded! ArgoCD will sync EKS cluster automatically."
        }
        failure {
            echo "Pipeline failed. Check logs above."
        }
        always {
            cleanWs()
        }
    }
}
